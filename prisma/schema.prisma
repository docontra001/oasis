generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Animal {
  id             String  @id
  slug           String
  nome           String?
  nomeCientifico String
  reino          String?
  filo           String?
  classe         String?
  ordem          String?
  familia        String?
  genero         String?
  destaque       Boolean @default(false)
  imagem         String?
}
